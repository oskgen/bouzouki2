<!DOCTYPE html>
<html lang="sv">
<head>
<meta charset="UTF-8">
<title>Bouzouki Rhythm Station</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<style>
body {
  font-family: Arial, sans-serif;
  background: #f4f4f4;
  text-align: center;
  padding: 20px;
}
.container {
  max-width: 600px;
  margin: auto;
  background: white;
  padding: 25px;
  border-radius: 12px;
  box-shadow: 0 8px 30px rgba(0,0,0,0.2);
}
h1 { margin-top: 0; }
label { display:block; margin-top:15px; font-weight:bold; }
input, select { width:100%; padding:8px; margin-top:5px; }
button {
  margin-top:20px;
  padding:15px;
  width:100%;
  font-size:18px;
  cursor:pointer;
}
</style>
</head>
<body>

<div class="container">
<h1>🎸 Bouzouki Rhythm Station</h1>

<label>Rytm</label>
<select id="rhythmType">
  <option value="jig">Jig (6/8)</option>
  <option value="reel">Reel (4/4)</option>
  <option value="hornpipe">Hornpipe (Swing)</option>
  <option value="polka">Polka (2/4)</option>
  <option value="slipjig">Slip Jig (9/8)</option>
</select>

<label>Tempo: <span id="bpmVal">90</span> BPM</label>
<input type="range" id="tempo" min="40" max="130" value="90">

<label>Volym: <span id="volVal">75</span>%</label>
<input type="range" id="volume" min="0" max="100" value="75">

<button id="playBtn">STARTA</button>
</div>

<script>
let isPlaying = false;
let currentBeat = 0;
let nextNoteTime = 0;
let timerID;

const lookahead = 25.0;
const scheduleAheadTime = 0.1;

let bpm = 90;
let volume = 0.75;

const audioCtx = new (window.AudioContext || window.webkitAudioContext)();

const GDAD = {
  D2: 73.42,
  G2: 98.00,
  A2: 110.00,
  D3: 146.83
};

const progression = [
  [GDAD.D2, GDAD.A2, GDAD.D3],
  [GDAD.G2, GDAD.D3],
  [GDAD.A2, GDAD.D3]
];

const rhythmConfig = {
  jig:      { beats: 6, accent: [0,3] },
  reel:     { beats: 4, accent: [0] },
  hornpipe: { beats: 4, accent: [0,2], swing: true },
  polka:    { beats: 2, accent: [0] },
  slipjig:  { beats: 9, accent: [0,3,6] }
};

function nextNote() {
  const secondsPerBeat = 60.0 / bpm;
  nextNoteTime += secondsPerBeat;
  currentBeat++;
}

function scheduler() {
  while (nextNoteTime < audioCtx.currentTime + scheduleAheadTime) {
    scheduleStrum(currentBeat, nextNoteTime);
    nextNote();
  }
  timerID = setTimeout(scheduler, lookahead);
}

function scheduleStrum(beat, time) {
  const type = document.getElementById("rhythmType").value;
  const config = rhythmConfig[type];
  const chord = progression[Math.floor(beat/config.beats) % progression.length];
  const downstroke = beat % 2 === 0;
  const accent = config.accent.includes(beat % config.beats);

  playChord(chord, time, downstroke, accent, config);
}

function playChord(notes, time, downstroke, accent, config) {
  notes.forEach((freq,i)=>{
    const osc = audioCtx.createOscillator();
    const gain = audioCtx.createGain();

    osc.type = "triangle";
    osc.frequency.value = freq;

    let spread = downstroke ? i*0.01 : (notes.length-i)*0.01;

    if(config.swing && currentBeat%2===1)
      spread += 0.02;

    spread += (Math.random()-0.5)*0.01;

    gain.gain.setValueAtTime(volume*(accent?1:0.6), time+spread);
    gain.gain.exponentialRampToValueAtTime(0.001, time+0.4);

    osc.connect(gain);
    gain.connect(audioCtx.destination);

    osc.start(time+spread);
    osc.stop(time+0.5);
  });
}

document.getElementById("playBtn").addEventListener("click", async ()=>{
  bpm = parseInt(document.getElementById("tempo").value);
  volume = parseInt(document.getElementById("volume").value)/100;

  if(audioCtx.state==="suspended") await audioCtx.resume();

  if(!isPlaying){
    currentBeat=0;
    nextNoteTime=audioCtx.currentTime;
    scheduler();
    document.getElementById("playBtn").innerText="STOPPA";
  } else {
    clearTimeout(timerID);
    document.getElementById("playBtn").innerText="STARTA";
  }

  isPlaying=!isPlaying;
});

document.getElementById("tempo").addEventListener("input", e=>{
  document.getElementById("bpmVal").innerText=e.target.value;
});

document.getElementById("volume").addEventListener("input", e=>{
  document.getElementById("volVal").innerText=e.target.value;
});
</script>

</body>
</html>
